# =========================
# Phoenix API - Environment
# =========================

# Server
PORT=4000
NODE_ENV=development

# Database - Neon PostgreSQL
# Usar la URL pooled de Neon para la app
DATABASE_URL="postgresql://USER:PASSWORD@HOST.neon.tech/DB_NAME?sslmode=require"

# Direct URL - Neon PostgreSQL
# Usar la URL direct connection para migraciones Prisma
DIRECT_URL="postgresql://USER:PASSWORD@HOST.neon.tech/DB_NAME?sslmode=require"

# OpenAQ
# Obtener API Key desde OpenAQ
OPENAQ_API_KEY="your_openaq_api_key_here"