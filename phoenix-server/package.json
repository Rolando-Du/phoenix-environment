{
  "name": "clearzone-server",
  "version": "1.0.0",
  "description": "Backend de CLEARZONE para monitoreo ambiental de calidad del aire y clima actual.",
  "main": "src/server.ts",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc --noEmit",
    "start": "tsx src/server.ts",
    "prisma:deploy": "prisma migrate deploy",
    "postinstall": "prisma generate"
  },
  "keywords": [
    "clearzone",
    "environment",
    "air-quality",
    "weather",
    "aqi",
    "openaq",
    "openmeteo",
    "openweather"
  ],
  "author": "Rolando Du / Yani Leiba",
  "license": "ISC",
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "^11.1.3",
      "onFail": "download"
    }
  },
  "type": "module",
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "pg": "^8.21.0",
    "tsx": "^4.22.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.9.1",
    "@types/pg": "^8.20.0",
    "prisma": "^7.8.0",
    "typescript": "^6.0.3"
  }
}