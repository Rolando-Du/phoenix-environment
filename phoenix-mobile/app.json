{
  "expo": {
    "name": "CLEARZONE",
    "slug": "clearzone",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/logo-CZ.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/logo-CZ.png",
      "resizeMode": "contain",
      "backgroundColor": "#0B0F1A"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/logo-CZ.png",
        "backgroundColor": "#0B0F1A"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/logo-CZ.png"
    }
  }
}